# ============================================================
# Agent Hunt — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
AH_POSTGRES_USER=agent_hunt
AH_POSTGRES_PASSWORD=agent_hunt_dev
AH_POSTGRES_HOST=localhost
AH_POSTGRES_PORT=5432
AH_POSTGRES_DB=agent_hunt

# --- Redis ---
AH_REDIS_HOST=localhost
AH_REDIS_PORT=6379
AH_REDIS_DB=0

# --- Gemini API (required for JD parsing) ---
AH_GEMINI_API_KEY=your-gemini-api-key
AH_GEMINI_MODEL=gemini-2.5-flash

# --- App ---
AH_DEBUG=false

# --- Currency conversion (fixed rates, CNY as base) ---
AH_USD_TO_CNY=7.25
AH_EUR_TO_CNY=7.90

# --- Docker Compose overrides ---
POSTGRES_USER=agent_hunt
POSTGRES_PASSWORD=agent_hunt_dev
POSTGRES_DB=agent_hunt
POSTGRES_PORT=5432
REDIS_PORT=6379
